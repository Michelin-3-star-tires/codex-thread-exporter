#!/bin/sh

commit_msg_file="$1"
first_line=$(head -n 1 "$commit_msg_file")

case "$first_line" in
  feat:*|fix:*|docs:*|style:*|refactor:*|perf:*|test:*|chore:*)
    :
    ;;
  *)
    echo "提交信息格式错误：必须是 Conventional Commits，例如 feat: 增加导出功能" >&2
    exit 1
    ;;
esac

subject=${first_line#*: }
case "$subject" in
  *[![:space:][:ascii:]]*)
    :
    ;;
  *)
    echo "提交主题建议使用中文，且不能为空" >&2
    exit 1
    ;;
esac

